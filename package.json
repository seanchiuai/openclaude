{
  "name": "openclaude",
  "version": "0.1.0",
  "description": "Autonomous AI assistant powered by Claude Code CLI",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.23.0",
  "bin": {
    "openclaude": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src/",
    "format": "oxfmt --write src/"
  },
  "dependencies": {
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^11.8.1",
    "croner": "^10.0.1",
    "grammy": "^1.41.1",
    "hono": "^4.12.7",
    "chokidar": "^5.0.0",
    "file-type": "^21.3.1",
    "pdfjs-dist": "^5.5.207",
    "sharp": "^0.34.5",
    "sqlite-vec": "0.1.7-alpha.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "oxfmt": "^0.7.0",
    "oxlint": "^1.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}