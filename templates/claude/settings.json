{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "command": "__OPENCLAUDE_DIR__/scripts/auto-retain.sh __AGENT_DIR__ __AGENT_NAME__ __HINDSIGHT_PORT__"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
